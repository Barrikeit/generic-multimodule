<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="APP_NAME">${spring:application.name}</Property>
        <Property name="APP_VERSION">${spring:application.version}</Property>
        <Property name="APP_BUILD">${spring:application.build}</Property>
        <Property name="LOG_PATH">${spring:logging.file.path}</Property>
        <Property name="LOG_PATTERN">
            %style{%date{yyyy-MM-dd HH:mm:ss.SSS}}{blue} %highlight{%-5level}{FATAL=bg_red, ERROR=red, WARN=yellow, INFO=green, DEBUG=blue} --- [%thread{20}] [%X{requestId:-no-req-id}] %style{%-20logger}{cyan} - %message%n
        </Property>
    </Properties>
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}" disableAnsi="false"/>
        </Console>
        <RollingFile name="RollingFile"
                     fileName="${LOG_PATH}/${APP_NAME}-${APP_VERSION}-b${APP_BUILD}.log"
                     filePattern="${LOG_PATH}/archived/${APP_NAME}-${APP_VERSION}-b${APP_BUILD}-%d{yyyy-MM-dd}-%i.log.gz"
                     append="false">
            <PatternLayout pattern="${LOG_PATTERN}" disableAnsi="true"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="200 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30" fileIndex="min"/>
        </RollingFile>
    </Appenders>
    <Loggers>
        <Root level="${sys:LOG_LEVEL_APP:-info}">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Root>
        <Logger name="dev.barrikeit" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Logger>
        <!-- Other loggers -->
        <Logger name="org.springframework" level="ERROR"/>
        <Logger name="org.hibernate" level="ERROR"/>
        <Logger name="com.zaxxer.hikari" level="ERROR"/>
    </Loggers>
</Configuration>